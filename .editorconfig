root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,md,csproj,props,targets}]
indent_size = 2

[*.cs]
# Namespace style
csharp_style_namespace_declarations = file_scoped:warning

# Usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Modern C#
csharp_prefer_braces = true:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion

# Nullable
dotnet_diagnostic.CS8600.severity = warning
dotnet_diagnostic.CS8602.severity = warning
dotnet_diagnostic.CS8603.severity = warning

# AOT / trim warnings escalated
dotnet_diagnostic.IL2026.severity = error
dotnet_diagnostic.IL2070.severity = error
dotnet_diagnostic.IL2075.severity = error
dotnet_diagnostic.IL3050.severity = error
dotnet_diagnostic.IL3052.severity = error
